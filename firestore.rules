rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- sticklet helpers ----------
    function isSchoolUser() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email.lower().matches('.*@ssis\\.edu\\.vn$')
        && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSchoolUser()
        && request.auth.token.email.lower() == 'lmeldrum@ssis.edu.vn';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidRoom(data) {
      return data.keys().hasOnly(['createdAt', 'createdByUid', 'createdByEmail', 'createdByName']) &&
             data.keys().hasAll(['createdAt', 'createdByUid', 'createdByEmail', 'createdByName']) &&
             data.createdAt == request.time &&
             data.createdByUid == request.auth.uid &&
             data.createdByEmail == request.auth.token.email &&
             data.createdByName is string && data.createdByName.size() <= 200;
    }

    function isValidNote(data) {
      return data.keys().hasOnly(['text', 'authorUid', 'authorEmail', 'authorName', 'color', 'createdAt', 'x', 'y']) &&
             data.keys().hasAll(['text', 'authorUid', 'authorEmail', 'authorName', 'color', 'createdAt', 'x', 'y']) &&
             data.text is string && data.text.size() <= 1000 &&
             data.authorUid == request.auth.uid &&
             data.authorEmail == request.auth.token.email &&
             data.authorName is string && data.authorName.size() <= 200 &&
             data.color is string && data.color in ['yellow', 'blue', 'green', 'pink', 'purple'] &&
             data.createdAt == request.time &&
             data.x is number && data.x >= 0 && data.x <= 100 &&
             data.y is number && data.y >= 0 && data.y <= 100;
    }

    // ---------- sticklet ----------
    match /rooms/{roomId} {
      allow get: if isSchoolUser() && isValidId(roomId);
      allow list: if isAdmin();
      allow create: if isSchoolUser() && isValidId(roomId) && isValidRoom(incoming());
      allow update: if false; // rooms are immutable
      allow delete: if isAdmin();

      match /notes/{noteId} {
        allow list, get: if isSchoolUser() && isValidId(roomId);

        allow create: if isSchoolUser() && isValidId(roomId) && isValidId(noteId) && isValidNote(incoming());

        // Only the author can edit, and only text/x/y. Static fields preserved.
        allow update: if isSchoolUser() &&
                      existing().authorUid == request.auth.uid &&
                      incoming().authorUid == existing().authorUid &&
                      incoming().authorEmail == existing().authorEmail &&
                      incoming().authorName == existing().authorName &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().color == existing().color &&
                      incoming().text is string && incoming().text.size() <= 1000 &&
                      incoming().x is number && incoming().x >= 0 && incoming().x <= 100 &&
                      incoming().y is number && incoming().y >= 0 && incoming().y <= 100 &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['text', 'x', 'y']);

        // Authors can delete their own notes; admin can delete any.
        allow delete: if isSchoolUser() && (existing().authorUid == request.auth.uid || isAdmin());
      }
    }

    // ---------- existing collections (preserved from prior rules) ----------
    match /boomers_campaigns/{document=**} {
      allow read, write: if true;
    }

    // AP Review - Students collection (PIN auth) - server-side only writes
    match /apr-students/{email} {
      allow read, write: if false; // server-only via Admin SDK
    }
    // AP Review - Admins collection - server-only
    match /apr-admins/{email} {
      allow read, write: if false;
    }
    // AP Review - User data - owner only
    match /apr-users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /frqs/{document=**} {
      allow read, write: if true;
    }

    match /credentials/{username} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /astrophysics_progress/{document=**} {
      allow read, write: if true;
    }

    // Cat blood sugar readings
    match /catReadings/{readingId} {
      allow read, write: if true;
    }

    // Meta collection for app flags
    match /meta/{docId} {
      allow read, write: if true;
    }
  }
}
