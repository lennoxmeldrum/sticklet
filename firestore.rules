rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers (used by sticklet rooms/notes) ----------
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidRoom(data) {
      return data.keys().hasAll(['createdAt']) &&
             data.keys().size() == 1 &&
             data.createdAt == request.time;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['text', 'authorId', 'color', 'createdAt', 'x', 'y']) &&
             data.keys().size() == 6 &&
             data.text is string && data.text.size() <= 1000 &&
             data.authorId is string && data.authorId.size() <= 128 &&
             data.color is string && data.color in ['yellow', 'blue', 'green', 'pink', 'purple'] &&
             data.createdAt == request.time &&
             data.x is number && data.x >= 0 && data.x <= 100 &&
             data.y is number && data.y >= 0 && data.y <= 100;
    }

    // ---------- sticklet ----------
    match /rooms/{roomId} {
      allow get: if isValidId(roomId);
      allow create: if isValidId(roomId) && isValidRoom(incoming());
      allow update: if false;
      allow delete: if false;
      allow list: if false;

      match /notes/{noteId} {
        allow list, get: if isValidId(roomId);
        allow create: if isValidId(roomId) && isValidId(noteId) && isValidNote(incoming());
        allow update: if isValidId(roomId) && isValidId(noteId) &&
                      incoming().authorId == existing().authorId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().color == existing().color &&
                      incoming().text is string && incoming().text.size() <= 1000 &&
                      incoming().x is number && incoming().x >= 0 && incoming().x <= 100 &&
                      incoming().y is number && incoming().y >= 0 && incoming().y <= 100 &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['text', 'x', 'y']);
        allow delete: if isValidId(roomId) && isValidId(noteId);
      }
    }

    // ---------- existing collections (preserved from prior rules) ----------
    match /boomers_campaigns/{document=**} {
      allow read, write: if true;
    }

    // AP Review - Students collection (PIN auth) - server-side only writes
    match /apr-students/{email} {
      allow read, write: if false; // server-only via Admin SDK
    }
    // AP Review - Admins collection - server-only
    match /apr-admins/{email} {
      allow read, write: if false;
    }
    // AP Review - User data - owner only
    match /apr-users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /frqs/{document=**} {
      allow read, write: if true;
    }

    match /credentials/{username} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /astrophysics_progress/{document=**} {
      allow read, write: if true;
    }

    // Cat blood sugar readings
    match /catReadings/{readingId} {
      allow read, write: if true;
    }

    // Meta collection for app flags
    match /meta/{docId} {
      allow read, write: if true;
    }
  }
}
